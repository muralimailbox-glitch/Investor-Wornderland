# ── dependencies ──────────────────────────────────────────────────────
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ── next.js ───────────────────────────────────────────────────────────
/.next/
/out/

# ── production ────────────────────────────────────────────────────────
/build

# ── testing ───────────────────────────────────────────────────────────
/coverage
/playwright-report
/test-results
/playwright/.cache

# ── ML models (downloaded at runtime by Xenova transformers) ─────────
/models

# ── env files (commit .env.example only) ──────────────────────────────
.env
.env.*
!.env.example

# ── prod database backups (never commit) ─────────────────────────────
backups/

# ── misc ──────────────────────────────────────────────────────────────
.DS_Store
*.pem
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ── vercel (not deploying to vercel, but keep ignored) ────────────────
.vercel

# ── typescript ────────────────────────────────────────────────────────
*.tsbuildinfo
next-env.d.ts

# ── editor ────────────────────────────────────────────────────────────
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
.idea/

# ── drizzle migrations metadata (regenerable) ─────────────────────────
# keep generated SQL, ignore journal artifacts only if the tool regenerates them
