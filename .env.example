# ┌─────────────────────────────────────────────────────────────────────┐
# │ OotaOS Investor Wonderland — environment template                   │
# │ Copy to .env.local for local dev; set real values in Railway vars.  │
# │ NEVER commit a populated .env file. This file is the only one that  │
# │ is safe to commit and it must contain every variable the app reads. │
# └─────────────────────────────────────────────────────────────────────┘

# ── Runtime ─────────────────────────────────────────────────────────────
NODE_ENV=development
# Production: https://investors.ootaos.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Database (Railway Postgres + pgvector) ──────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ootaos

# ── Anthropic Claude ────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL_CONCIERGE=claude-opus-4-7
ANTHROPIC_MODEL_DRAFTER=claude-sonnet-4-6
AI_MONTHLY_CAP_USD=50

# ── Zoho SMTP (outbound mail) ───────────────────────────────────────────
SMTP_HOST=smtp.zoho.in
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=info@ootaos.com
SMTP_PASS=
SMTP_FROM=info@ootaos.com
SMTP_FROM_NAME=OotaOS

# ── Zoho IMAP (inbound mail polling) ────────────────────────────────────
IMAP_HOST=imap.zoho.in
IMAP_PORT=993
IMAP_USER=info@ootaos.com
IMAP_PASS=

# ── Object storage (S3-compatible) ──────────────────────────────────────
# Prod: Cloudflare R2. Dev: local MinIO via docker-compose.
# R2_ENDPOINT is optional — when set, used verbatim; otherwise we build
# https://${R2_ACCOUNT_ID}.r2.cloudflarestorage.com (Cloudflare).
R2_ENDPOINT=
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=ootaos-docs
R2_PUBLIC_URL=https://docs.ootaos.com
R2_FORCE_PATH_STYLE=false

# ── Auth (Lucia v3 + sessions) ──────────────────────────────────────────
AUTH_SECRET=
SESSION_COOKIE_NAME=ootaos_session

# ── Founder bootstrap (seeded on first deploy; rotate by changing here) ──
# Replace with the OotaOS founder's real address and a strong password
# before deploying. Never commit a populated value here.
FOUNDER_EMAIL=founder@example.com
FOUNDER_PASSWORD=replace-me-with-a-strong-password
FOUNDER_FIRST_NAME=Founder

# Emergency founder re-provisioner — defaults to false. Set to true only
# when you need to call POST /api/v1/admin/bootstrap to re-seed the founder
# row after a deploy; flip back to false immediately afterwards.
ENABLE_BOOTSTRAP_ROUTE=false

# ── Google Calendar (OAuth) ─────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://www.ootaos.com/api/v1/oauth/google/callback

# ── Observability ───────────────────────────────────────────────────────
SENTRY_DSN=
