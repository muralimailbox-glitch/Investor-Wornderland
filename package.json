{
  "name": "ootaos-investor-wonderland",
  "version": "0.1.0",
  "private": true,
  "description": "OotaOS Investor Wonderland — an AI-native investor relations platform",
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@9.15.9",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint --max-warnings=0",
    "lint:fix": "eslint --fix",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx src/lib/db/seed.ts",
    "import-investors": "tsx scripts/import-investors.ts",
    "seed:knowledge": "tsx scripts/seed-knowledge.ts",
    "ingest:pack": "tsx scripts/ingest-investor-pack.ts",
    "ingest:corpus": "tsx scripts/ingest-corpus.ts",
    "crawl:web": "tsx scripts/crawl-ootaos.ts",
    "qa:synth": "tsx scripts/synthesize-qa.ts",
    "ingest:full": "tsx scripts/seed-knowledge.ts && tsx scripts/ingest-corpus.ts && tsx scripts/crawl-ootaos.ts && tsx scripts/synthesize-qa.ts",
    "refresh:knowledge": "tsx scripts/seed-knowledge.ts && tsx scripts/ingest-corpus.ts --prune-missing && tsx scripts/crawl-ootaos.ts && tsx scripts/synthesize-qa.ts --refresh",
    "preview:extractors": "tsx scripts/preview-extractors.ts",
    "backup:prod": "tsx scripts/backup-prod.ts",
    "backup:check": "tsx scripts/backup-prod.ts --check",
    "row-counts": "tsx scripts/backup-prod.ts --row-counts",
    "inventory:investors": "tsx scripts/run-sql.ts scripts/inventory-investor-fields.sql",
    "refactor:drop-legacy": "tsx scripts/run-sql.ts drizzle/manual/drop-legacy-investor-cols.sql",
    "backfill:leads": "tsx scripts/backfill-leads-from-investors.ts",
    "bootstrap": "tsx scripts/bootstrap.ts",
    "ingest:all": "tsx scripts/seed-knowledge.ts && tsx scripts/ingest-investor-pack.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepare": "husky || true"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.91.0",
    "@aws-sdk/client-s3": "^3.1036.0",
    "@aws-sdk/s3-request-presigner": "^3.1036.0",
    "@lucia-auth/adapter-drizzle": "^1.1.0",
    "@oslojs/crypto": "^1.0.1",
    "@oslojs/encoding": "^1.1.0",
    "@oslojs/otp": "^1.1.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/nodemailer": "^8.0.0",
    "@types/pdf-parse": "^1.1.4",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@xenova/transformers": "^2.17.2",
    "argon2": "^0.44.0",
    "cheerio": "^1.0.0",
    "clsx": "^2.1.1",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.2",
    "framer-motion": "^12.38.0",
    "imapflow": "^1.3.2",
    "lucia": "^3.2.2",
    "lucide-react": "^1.9.0",
    "mammoth": "^1.12.0",
    "next": "16.2.4",
    "nodemailer": "^8.0.5",
    "officeparser": "^5.1.0",
    "p-limit": "^5.0.0",
    "pdf-lib": "^1.17.1",
    "pdf-parse": "^1.1.1",
    "pg-boss": "^12.16.0",
    "postgres": "^3.4.9",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "tailwindcss": "^4",
    "tsx": "^4.19.2",
    "typescript": "^5",
    "xlsx": "^0.18.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.2",
    "@ianvs/prettier-plugin-sort-imports": "^4.4.0",
    "@playwright/test": "^1.59.1",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "eslint-config-prettier": "^9.1.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.2.10",
    "prettier": "^3.3.3",
    "vitest": "^4.1.5"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml,css}": [
      "prettier --write"
    ]
  }
}
